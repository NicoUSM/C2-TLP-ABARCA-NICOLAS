generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Evento {
  idEvento          Int           @id @default(autoincrement()) @map("id_evento")
  titulo            String        @db.VarChar(100)
  fecha             DateTime      @db.Date
  hora              DateTime      @db.Time(0)
  lugar             String        @db.VarChar(150)
  imagen            String?       @db.VarChar(255)
  valor             Decimal       @default(0.00) @db.Decimal(10, 2)
  cantidadInscritos Int           @default(0) @map("cantidad_inscritos")
  inscripciones     Inscripcion[]

  @@map("eventos")
}

model Usuario {
  idUsuario     Int           @id @default(autoincrement()) @map("id_usuario")
  nombre        String        @db.VarChar(100)
  apellido      String        @db.VarChar(100)
  correo        String        @unique(map: "correo") @db.VarChar(100)
  fechaRegistro DateTime      @default(now()) @map("fecha_registro") @db.DateTime(0)
  inscripciones Inscripcion[]

  @@map("usuarios")
}

model Inscripcion {
  idInscripcion    Int      @id @default(autoincrement()) @map("id_inscripcion")
  idEvento         Int      @map("id_evento")
  idUsuario        Int      @map("id_usuario")
  fechaInscripcion DateTime @default(now()) @map("fecha_inscripcion") @db.DateTime(0)
  evento           Evento   @relation(fields: [idEvento], references: [idEvento], onDelete: Cascade, map: "fk_inscripciones_eventos")
  usuario          Usuario  @relation(fields: [idUsuario], references: [idUsuario], onDelete: Cascade, map: "fk_inscripciones_usuarios")

  @@unique([idEvento, idUsuario], map: "id_evento")
  @@index([idUsuario], map: "fk_inscripciones_usuarios")
  @@map("inscripciones")
}
